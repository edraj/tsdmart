{
  "compilerOptions": {
    "module": "es2022",
    "moduleResolution": "bundler",
    "target": "es2022",
    "strict": true,
    "isolatedModules": true,
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "paths": {
      "@": [
        "./src"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vitest/globals"
    ]

  },
  "include": [
    "vite-env.d.ts",
    "src/**/*.d.ts",
    "*.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    ".routify/**.js",
    "test/**/*.ts",
    "test/**/*.js"
  ],
  "exclude": [
    ".routify/**/*.svelte",
    ".routify/**/*.js",
    "node_modules/**/*.svelte",
    "node_modules/**/*.ts"
  ]
}
